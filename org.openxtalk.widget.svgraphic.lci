  use com.livecode.string
  use com.livecode.type
  use com.livecode.mathfoundation
  use com.livecode.byte
  use com.livecode.math
  use com.livecode.engine
  handler getForegroundColor() returns String
  handler setForegroundColor(in pColor as String) returns nothing
  handler setForegroundPattern(in pPattern as optional Number) returns nothing
  handler setFillGradient(in pGradientStops as optional String) returns nothing
  handler getFillGradient() returns optional any
  handler getGradientStops() returns String
  handler setGradientStops(in pColor as String) returns nothing
  handler getBackgroundColor() returns String
  handler setBackgroundColor(in pColor as String) returns nothing
  handler setBackgroundPattern(in pPattern as optional Number) returns nothing
  handler setBorderColor(in pColor as String) returns nothing
  handler getBorderColor() returns String
  handler setBorderPattern(in pPattern as optional Number) returns nothing
  handler setHiliteColor(in pColor as String) returns nothing
  handler getHiliteColor() returns String
  handler setHilitePattern(in pPattern as optional Number) returns nothing
  handler setTextAlign(in pColor as String) returns optional any
  handler getTextAlign() returns optional any
  handler setBorderWidth(in pBorderWidth as Number) returns nothing
  handler setIsHilited(in pBoolean as Boolean) returns optional any
  handler setMaintainAspectRatio(in pBoolean as Boolean) returns optional any
  handler setFillRule(in pColor as String) returns nothing
  handler OnCreate() returns optional any
  handler OnSave(out rProperties as Array) returns optional any
  handler OnLoad(in pProperties as Array) returns optional any
  handler OnGeometryChanged() returns optional any
  handler OnMouseUp() returns optional any
  handler OnMouseDown() returns optional any
  handler OnMouseEnter() returns optional any
  handler OnMouseLeave() returns optional any
  handler setFlipVertically(in pBoolean as Boolean) returns optional any
  handler setPath(in pColor as String) returns nothing
  handler setPoints(in pColor as String) returns nothing
  handler setPathPreset(in pColor as String) returns nothing
  handler setAngle(in pBorderWidth as Number) returns nothing
  handler OnPaint() returns optional any
end module
